{
  "name": "rest-express",
  "version": "1.0.0",
  "engines": {
    "node": "20.x"
  },
  "type": "module",
  "license": "MIT",
  "scripts": {
    "db:sqlite:push": "drizzle-kit push --config=drizzle.sqlite.config.ts",
    "dev": "set NODE_ENV=development&& nodemon --watch server --ext ts,js,json --exec tsx server/index.ts",
    "dev:server:esm": "set NODE_ENV=development&& tsx watch server/index.ts",
    "client": "vite --config vite.config.ts",
    "predev:live": "npx --yes kill-port 5000 5173 6100 8888",
    "dev:live": "npm run start:clean && concurrently -k -p \"[{name}]\" -n \"SERVER,CLIENT\" -c \"cyan.bold,green.bold\" \"npm run dev:server:esm\" \"npm run client\"",
    "start:clean": "npx --yes kill-port 5000 5173 6100 8888",
    "start:server": "npm run dev:server:esm",
    "start:client": "npm run client",
    "start:all": "npm run start:clean && start powershell -NoExit -Command npm run start:server && npm run start:client",
    "build": "vite build && node scripts/postbuild-spa-404.cjs && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "build:client": "vite build && node scripts/postbuild-spa-404.cjs",
    "preflight": "node scripts/preflight.cjs",
    "deploy:safe": "npm run preflight && git add -A && git commit --allow-empty -m \"chore(deploy): safe deploy (preflight ok) FORCE_PAGES_DEPLOY\" && git push origin main",
    "deploy:force": "git commit --allow-empty -m \"chore(deploy): force pages rebuild FORCE_PAGES_DEPLOY\" && git push origin main",
    "start": "node dist/index.js",
    "verify-env": "node scripts/verify-env.mjs DATABASE_URL GEMINI_API_KEY JWT_SECRET",
    "health": "node scripts/health-check.mjs http://localhost:5000/health",
    "proxy:start": "node server/proxy-engine/server.mjs",
    "proxy:health": "node -e \"fetch('http://localhost:8080/health').then(r=>r.json()).then(d=>console.log(d))\"",
    "render:build": "npm install --include=dev && npx esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "build:rust": "cd server/rust-verifier && cargo build && cd ../..",
    "build:rust:release": "cd server/rust-verifier && cargo build --release && cd ../...",
    "check": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:integration": "vitest run tests/api.test.ts",
    "db:push": "drizzle-kit push",
    "db:check": "node scripts/db-check.mjs",
    "git:fetch": "git fetch origin --quiet",
    "remote:file": "node scripts/remote-file.mjs",
    "diff:file": "node scripts/diff-file.mjs",
    "backup:file": "node scripts/backup-file.mjs",
    "restore:file": "node scripts/restore-file.mjs",
    "restore:core": "npm run restore:file -- client/src/index.css && npm run restore:file -- client/src/mobile-overrides.css && npm run restore:file -- client/src/components/navigation.tsx",
    "diff:core": "npm run git:fetch && npm run diff:file -- client/src/index.css && npm run diff:file -- client/src/mobile-overrides.css && npm run diff:file -- client/src/components/navigation.tsx",
    "snapshot:main": "node scripts/snapshot-main.mjs",
    "vm:status": "node scripts/oci-vm.mjs status",
    "vm:stop": "node scripts/oci-vm.mjs stop",
    "vm:start": "node scripts/oci-vm.mjs start",
    "vm:reboot": "node scripts/oci-vm.mjs reboot",
    "vm:ssh": "ssh -i C:\\Users\\guita\\.ssh\\oracle_bongbari2 opc@79.76.110.66",
    "vm:setup-proxy": "ssh -i C:\\Users\\guita\\.ssh\\oracle_bongbari2 opc@79.76.110.66 < scripts/setup-proxy-engine.sh"
  },
